apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

namespace: {{.KubernetesNamespaceProd}}

resources:
  - ../../base
  - hpa.yaml
  - ingress.yaml

images:
  - name: your-registry/{{.KubernetesName}}-user-service
    newName: your-registry/{{.KubernetesName}}-user-service
    newTag: v1.0.0
  - name: your-registry/{{.KubernetesName}}-order-service
    newName: your-registry/{{.KubernetesName}}-order-service
    newTag: v1.0.0
  - name: your-registry/{{.KubernetesName}}-product-service
    newName: your-registry/{{.KubernetesName}}-product-service
    newTag: v1.0.0

patches:
  - path: deployment-patch.yaml
