app:
  name: user-service
  env: development
  address: ":8081"

service:
  name: user-service

rpc:
  mode: grpc
  grpc:
    address: ":9081"

server:
  http:
    addr: ":8081"
    mode: debug

database:
  driver: sqlite
  dsn: user.db

redis:
  addr: "${REDIS_ADDR:localhost:6379}"
  password: ""
  db: 0

log:
  level: debug

tracing:
  enabled: true
  backend: otel
  service_name: user-service
  otel:
    endpoint: "${JAEGER_ENDPOINT:localhost:4317}"
  sampling_rate: 1.0

metadata:
  enabled: true
  propagate_prefix:
    - x-md-

service_auth:
  mode: token
  token:
    secret: "change-me-in-production"
    issuer: "user-service"
    audience: "internal"
    expiry: 3600
  allowed_services:
    - order-service

cache:
  driver: memory

distributed_lock:
  enabled: false
  backend: redis
  redis:
    addr: "${REDIS_ADDR:localhost:6379}"
    password: ""
    db: 0
  key_prefix: lock:

message_queue:
  enabled: false
  backend: redis
  redis:
    addr: "${REDIS_ADDR:localhost:6379}"
    password: ""
    db: 0

# 治理覆盖配置
# - mode 由 cmd/app/main.go 中的 gorp.WithMicroserviceMode() 决定
# - disable 用于显式关闭某个默认治理件
# - providers 用于显式替换默认 provider backend
governance:
  disable: []
  providers: {}
  # 示例：
  # disable:
  #   - tracing
  # providers:
  #   serviceauth: mtls

# 如需服务发现，可再开启
