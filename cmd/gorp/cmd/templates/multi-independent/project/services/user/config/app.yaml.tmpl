app:
  name: user-service
  env: dev
  address: ":8081"

service:
  name: user-service

rpc:
  mode: grpc
  grpc:
    address: ":9081"

server:
  http:
    addr: ":8081"
    mode: debug

database:
  driver: sqlite
  dsn: user.db

redis:
  addr: "${REDIS_ADDR:localhost:6379}"
  password: ""
  db: 0

log:
  level: debug

tracing:
{{- if .IsMicroGovernance }}
  enabled: true
{{- else }}
  enabled: false
{{- end }}
  backend: otel
  service_name: user-service
  otel:
    endpoint: "${JAEGER_ENDPOINT:localhost:4317}"
  sampling_rate: 1.0

metadata:
{{- if .IsMicroGovernance }}
  enabled: true
{{- else }}
  enabled: false
{{- end }}
  propagate_prefix:
    - x-md-

service_auth:
{{- if .IsMicroGovernance }}
  mode: token
  token:
    secret: "change-me-in-production"
    issuer: "user-service"
    audience: "internal"
    expiry: 3600
  allowed_services:
    - order-service
{{- else }}
  mode: noop
  token:
    secret: "change-me-in-production"
    issuer: "user-service"
    audience: ""
    expiry: 3600
  allowed_services: []
{{- end }}

cache:
  driver: memory

distributed_lock:
  enabled: false
  backend: redis
  redis:
    addr: "${REDIS_ADDR:localhost:6379}"
    password: ""
    db: 0
  key_prefix: lock:

message_queue:
  enabled: false
  backend: redis
  redis:
    addr: "${REDIS_ADDR:localhost:6379}"
    password: ""
    db: 0

# 治理覆盖配置
governance:
{{- if .IsMicroGovernance }}
  disable: []
  providers:
    tracing: otel
    selector: p2c_ewma
    serviceauth: token
    circuitbreaker: sentinel
{{- else }}
  disable: []
  providers: {}
{{- end }}

# circuit_breaker 配置
circuit_breaker:
{{- if .IsMicroGovernance }}
  enabled: true
  backend: sentinel
  sentinel:
    strategy: error_count
    threshold: 50
    retry_timeout_ms: 5000
{{- else }}
  enabled: false
  backend: sentinel
{{- end }}

# selector 配置
selector:
{{- if .IsMicroGovernance }}
  enabled: true
  backend: p2c_ewma
{{- else }}
  enabled: false
  backend: random
{{- end }}

