package handler

import (
	"net/http"
	"strconv"

{{- if .IsGinHTTPMode }}
	"{{.ModuleName}}/services/user/internal/server/http/request"
	"{{.ModuleName}}/services/user/internal/server/http/response"
	"{{.ModuleName}}/services/user/internal/service"

	"github.com/gin-gonic/gin"
{{- else }}
	gorp "{{.FrameworkModule}}"
	"{{.FrameworkModule}}/framework/httpx"
	"{{.ModuleName}}/services/user/internal/server/http/request"
	"{{.ModuleName}}/services/user/internal/server/http/response"
	"{{.ModuleName}}/services/user/internal/service"
{{- end }}
)

type UserHandler struct {
	user *service.UserService
}

func NewUserHandler(user *service.UserService) *UserHandler {
	return &UserHandler{user: user}
}

{{- if .IsGinHTTPMode }}

func (h *UserHandler) List(c *gin.Context) {
	page, _ := strconv.Atoi(c.DefaultQuery("page", "1"))
	size, _ := strconv.Atoi(c.DefaultQuery("size", "10"))

	items, total, err := h.user.List(c.Request.Context(), page, size)
	if err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"error": err.Error()})
		return
	}

	respItems := make([]response.User, len(items))
	for i, item := range items {
		respItems[i] = response.User{ID: item.ID, Username: item.Username, Email: item.Email}
	}

	c.JSON(http.StatusOK, response.UserList{
		Items: respItems,
		Total: total,
		Page:  page,
		Size:  size,
	})
}

func (h *UserHandler) GetByID(c *gin.Context) {
	id, err := strconv.ParseUint(c.Param("id"), 10, 64)
	if err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": "invalid id"})
		return
	}

	user, err := h.user.GetByID(c.Request.Context(), uint(id))
	if err != nil {
		c.JSON(http.StatusNotFound, gin.H{"error": "user not found"})
		return
	}

	c.JSON(http.StatusOK, response.User{ID: user.ID, Username: user.Username, Email: user.Email})
}

func (h *UserHandler) Create(c *gin.Context) {
	var req request.CreateUser
	if err := c.ShouldBindJSON(&req); err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": err.Error()})
		return
	}

	user, err := h.user.Create(c.Request.Context(), service.CreateUserRequest{
		Username: req.Username,
		Email:    req.Email,
	})
	if err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"error": err.Error()})
		return
	}

	c.JSON(http.StatusCreated, response.User{ID: user.ID, Username: user.Username, Email: user.Email})
}

func (h *UserHandler) Delete(c *gin.Context) {
	id, err := strconv.ParseUint(c.Param("id"), 10, 64)
	if err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": "invalid id"})
		return
	}

	if err := h.user.Delete(c.Request.Context(), uint(id)); err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"error": err.Error()})
		return
	}

	c.Status(http.StatusNoContent)
}
{{- else }}

func (h *UserHandler) List(c gorp.Context) {
	page, _ := strconv.Atoi(c.DefaultQuery("page", "1"))
	size, _ := strconv.Atoi(c.DefaultQuery("size", "10"))

	items, total, err := h.user.List(c.Context(), page, size)
	if err != nil {
		httpx.Error(c, err)
		return
	}

	respItems := make([]response.User, len(items))
	for i, item := range items {
		respItems[i] = response.User{ID: item.ID, Username: item.Username, Email: item.Email}
	}

	httpx.Success(c, response.UserList{
		Items: respItems,
		Total: total,
		Page:  page,
		Size:  size,
	})
}

func (h *UserHandler) GetByID(c gorp.Context) {
	id, err := strconv.ParseUint(c.Param("id"), 10, 64)
	if err != nil {
		httpx.BadRequest(c, "invalid id")
		return
	}

	user, err := h.user.GetByID(c.Context(), uint(id))
	if err != nil {
		c.JSON(http.StatusNotFound, map[string]any{"error": "user not found"})
		return
	}

	httpx.Success(c, response.User{ID: user.ID, Username: user.Username, Email: user.Email})
}

func (h *UserHandler) Create(c gorp.Context) {
	var req request.CreateUser
	if err := c.BindJSON(&req); err != nil {
		httpx.BadRequest(c, err.Error())
		return
	}

	user, err := h.user.Create(c.Context(), service.CreateUserRequest{
		Username: req.Username,
		Email:    req.Email,
	})
	if err != nil {
		httpx.Error(c, err)
		return
	}

	httpx.SuccessWithStatus(c, http.StatusCreated, response.User{ID: user.ID, Username: user.Username, Email: user.Email})
}

func (h *UserHandler) Delete(c gorp.Context) {
	id, err := strconv.ParseUint(c.Param("id"), 10, 64)
	if err != nil {
		httpx.BadRequest(c, "invalid id")
		return
	}

	if err := h.user.Delete(c.Context(), uint(id)); err != nil {
		httpx.Error(c, err)
		return
	}

	c.Status(http.StatusNoContent)
}
{{- end }}
