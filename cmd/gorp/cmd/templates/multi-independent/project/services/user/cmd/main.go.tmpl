package main

import (
	"fmt"
	"os"

	userdata "{{.ModuleName}}/services/user/internal/data"
	userhttp "{{.ModuleName}}/services/user/internal/server/http"
	"{{.FrameworkModule}}"
{{- if .IsMicroGovernance }}
	_ "{{.ModuleName}}/shared" // 微服务治理组件统一导入
{{- end }}
{{- if .IsGinHTTPMode }}
	transportcontract "{{.FrameworkModule}}/framework/contract/transport"
{{- end }}
)

func main() {
	if err := gorp.Run(
{{- if .IsMicroGovernance }}
		gorp.GRPC(),
		gorp.WithMicroGovernance(),
{{- else }}
		gorp.WithMonoGovernance(),
{{- end }}
{{- if .IsGinHTTPMode }}
		gorp.WithGinHTTPMode(),
{{- end }}
		gorp.WithMigrate(migrate),
		gorp.WithSetup(setup),
	); err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
}

func migrate(rt *gorp.HTTPRuntime) error {
	if rt == nil || rt.DB == nil {
		return nil
	}
	return rt.DB.AutoMigrate(&userdata.UserPO{})
}

func setup(rt *gorp.HTTPRuntime) error {
	if rt.DB == nil {
		return fmt.Errorf("user-service requires gorm database")
	}
	services, err := wireUserServices(rt.DB)
	if err != nil {
		return err
	}
{{- if .IsGinHTTPMode }}

	// Gin-first 模式：传递 HTTP 服务给路由注册函数
	httpSvc, err := rt.Container.Make(transportcontract.HTTPKey)
	if err != nil {
		return err
	}
	userhttp.RegisterRoutes(httpSvc.(transportcontract.HTTP), services)
{{- else }}
	userhttp.RegisterRoutes(rt.Router, services)
{{- end }}
	return nil
}
