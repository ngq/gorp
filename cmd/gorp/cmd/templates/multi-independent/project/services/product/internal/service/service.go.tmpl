package service

import (
	"context"

	"{{.ModuleName}}/services/product/internal/biz"
	"{{.ModuleName}}/services/product/internal/data"

	"gorm.io/gorm"
)

type Services struct {
	Product *ProductService
}

func NewServices(db *gorm.DB) *Services {
	productRepo := data.NewProductRepo(db)
	productUC := biz.NewProductUseCase(productRepo)
	return &Services{
		Product: &ProductService{uc: productUC},
	}
}

type ProductService struct {
	uc *biz.ProductUseCase
}

type CreateProductRequest struct {
	Name        string  `json:"name" binding:"required"`
	Description string  `json:"description"`
	Price       float64 `json:"price" binding:"required"`
	Stock       int     `json:"stock"`
}

type ProductResponse struct {
	ID          uint    `json:"id"`
	Name        string  `json:"name"`
	Description string  `json:"description"`
	Price       float64 `json:"price"`
	Stock       int     `json:"stock"`
	CreatedAt   int64   `json:"created_at"`
	UpdatedAt   int64   `json:"updated_at"`
}

func (s *ProductService) List(ctx context.Context, page, size int) ([]ProductResponse, int64, error) {
	products, total, err := s.uc.List(ctx, page, size)
	if err != nil {
		return nil, 0, err
	}

	items := make([]ProductResponse, len(products))
	for i, p := range products {
		items[i] = toProductResponse(p)
	}
	return items, total, nil
}

func (s *ProductService) GetByID(ctx context.Context, id uint) (*ProductResponse, error) {
	product, err := s.uc.GetByID(ctx, id)
	if err != nil {
		return nil, err
	}
	resp := toProductResponse(product)
	return &resp, nil
}

func (s *ProductService) Create(ctx context.Context, req CreateProductRequest) (*ProductResponse, error) {
	product, err := s.uc.Create(ctx, req.Name, req.Description, req.Price, req.Stock)
	if err != nil {
		return nil, err
	}
	resp := toProductResponse(product)
	return &resp, nil
}

func (s *ProductService) Delete(ctx context.Context, id uint) error {
	return s.uc.Delete(ctx, id)
}

func toProductResponse(p *biz.Product) ProductResponse {
	return ProductResponse{ID: p.ID, Name: p.Name, Description: p.Description, Price: p.Price, Stock: p.Stock, CreatedAt: p.CreatedAt.Unix(), UpdatedAt: p.UpdatedAt.Unix()}
}
