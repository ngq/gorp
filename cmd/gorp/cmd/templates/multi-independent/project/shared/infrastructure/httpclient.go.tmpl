package infrastructure

import (
	"bytes"
	"context"
	"encoding/json"
	"fmt"
	"io"
	"net/http"
	"time"

	"{{.ModuleName}}/shared/config"
	"go.opentelemetry.io/otel"
	"go.opentelemetry.io/otel/propagation"
)

// HTTPClient HTTP 客户端
type HTTPClient struct {
	client         *http.Client
	circuitBreaker *CircuitBreaker
	tracingEnabled bool
}

// NewHTTPClient 创建 HTTP 客户端
func NewHTTPClient(cfg *config.Config, cb *CircuitBreaker) *HTTPClient {
	return &HTTPClient{
		client: &http.Client{
			Timeout: 10 * time.Second,
		},
		circuitBreaker: cb,
		tracingEnabled: cfg.Tracing.Enabled,
	}
}

// Get 发送 GET 请求
func (c *HTTPClient) Get(ctx context.Context, url string, result interface{}) error {
	return c.doRequest(ctx, "GET", url, nil, result)
}

// Post 发送 POST 请求
func (c *HTTPClient) Post(ctx context.Context, url string, body interface{}, result interface{}) error {
	return c.doRequest(ctx, "POST", url, body, result)
}

func (c *HTTPClient) doRequest(ctx context.Context, method, url string, body interface{}, result interface{}) error {
	var reqBody io.Reader
	if body != nil {
		data, err := json.Marshal(body)
		if err != nil {
			return fmt.Errorf("marshal body: %w", err)
		}
		reqBody = bytes.NewReader(data)
	}

	doRequest := func() error {
		req, err := http.NewRequestWithContext(ctx, method, url, reqBody)
		if err != nil {
			return fmt.Errorf("create request: %w", err)
		}

		req.Header.Set("Content-Type", "application/json")

		// 注入链路追踪头
		if c.tracingEnabled {
			InjectTraceHeaders(ctx, req)
		}

		resp, err := c.client.Do(req)
		if err != nil {
			return fmt.Errorf("do request: %w", err)
		}
		defer resp.Body.Close()

		if resp.StatusCode >= 400 {
			return fmt.Errorf("request failed: status %d", resp.StatusCode)
		}

		if result != nil {
			data, err := io.ReadAll(resp.Body)
			if err != nil {
				return fmt.Errorf("read response: %w", err)
			}
			if err := json.Unmarshal(data, result); err != nil {
				return fmt.Errorf("unmarshal response: %w", err)
			}
		}

		return nil
	}

	// 使用熔断器保护
	if c.circuitBreaker != nil {
		return c.circuitBreaker.Execute(doRequest)
	}

	return doRequest()
}

// InjectTraceHeaders 注入链路追踪头
func InjectTraceHeaders(ctx context.Context, req *http.Request) {
	otel.GetTextMapPropagator().Inject(ctx, propagation.HeaderCarrier(req.Header))
}