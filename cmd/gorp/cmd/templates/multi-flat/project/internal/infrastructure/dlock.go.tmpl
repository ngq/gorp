package infrastructure

import (
	"context"
	"fmt"
	"time"

	"{{.ModuleName}}/internal/config"
)

// DistributedLock 分布式锁
type DistributedLock struct {
	redis     *RedisClient
	keyPrefix string
}

// NewDistributedLock 创建分布式锁
func NewDistributedLock(redis *RedisClient, cfg *config.Config) *DistributedLock {
	if !cfg.DistributedLock.Enabled || redis == nil {
		return nil
	}
	return &DistributedLock{
		redis:     redis,
		keyPrefix: cfg.DistributedLock.RedisKeyPrefix,
	}
}

// Lock 获取锁
func (l *DistributedLock) Lock(ctx context.Context, key string, ttl time.Duration) (bool, error) {
	fullKey := l.keyPrefix + key
	result, err := l.redis.Client().SetNX(ctx, fullKey, "1", ttl).Result()
	return result, err
}

// Unlock 释放锁
func (l *DistributedLock) Unlock(ctx context.Context, key string) error {
	fullKey := l.keyPrefix + key
	return l.redis.Del(ctx, fullKey)
}

// TryLock 尝试获取锁（带重试）
func (l *DistributedLock) TryLock(ctx context.Context, key string, ttl time.Duration, retryTimes int, retryInterval time.Duration) (bool, error) {
	for i := 0; i < retryTimes; i++ {
		ok, err := l.Lock(ctx, key, ttl)
		if err != nil {
			return false, err
		}
		if ok {
			return true, nil
		}
		time.Sleep(retryInterval)
	}
	return false, nil
}

// WithLock 使用锁执行函数
func (l *DistributedLock) WithLock(ctx context.Context, key string, ttl time.Duration, fn func() error) error {
	ok, err := l.Lock(ctx, key, ttl)
	if err != nil {
		return fmt.Errorf("acquire lock: %w", err)
	}
	if !ok {
		return fmt.Errorf("lock already held: %s", key)
	}
	defer l.Unlock(ctx, key)

	return fn()
}