package order

import (
	"fmt"

	frameworkbootstrap "{{.FrameworkModule}}/framework/bootstrap"
	orderdata "{{.ModuleName}}/services/order/internal/data"
	ordersvc "{{.ModuleName}}/services/order/internal/service"
)

// Start 启动 order 服务。
//
// 中文说明：
// - 这是 order 服务对外暴露的最小启动入口；
// - 真实业务装配仍然位于 services/order/internal/...；
// - cmd/order/main.go 只负责调用这里，避免直接跨越 internal 边界。
func Start() error {
	return frameworkbootstrap.BootHTTPService("order-service", frameworkbootstrap.HTTPServiceOptions{}, migrate, setup)
}

func migrate(rt *frameworkbootstrap.HTTPServiceRuntime) error {
	if rt.DB == nil {
		return nil
	}
	return rt.DB.AutoMigrate(&orderdata.OrderPO{})
}

func setup(rt *frameworkbootstrap.HTTPServiceRuntime) error {
	if rt.DB == nil {
		return fmt.Errorf("order-service requires gorm database")
	}
	services := ordersvc.NewServices(rt.DB)
	services.Order.RegisterRoutes(rt.Engine)
	return nil
}
