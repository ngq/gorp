# 用户服务配置
server:
  address: ":8081"
  mode: "debug"

db:
  dbname: "user"   # SQLite 数据库文件名

# Redis 配置
redis:
  addr: "${REDIS_ADDR:localhost:6379}"
  password: ""
  db: 0

# 服务发现配置
discovery:
  enabled: true
  type: "consul"  # consul / etcd / nacos
  consul:
    addr: "${CONSUL_ADDR:localhost:8500}"
    service_name: "user-service"
    service_port: 8081

# 链路追踪配置
tracing:
  enabled: true
  service_name: "user-service"
  endpoint: "${JAEGER_ENDPOINT:http://localhost:4318/v1/traces}"

# 限流配置
ratelimit:
  enabled: true
  requests_per_second: 100
  burst: 200

# 熔断配置
circuit_breaker:
  enabled: true
  threshold: 5
  timeout: 30s

# 缓存配置
cache:
  enabled: true
  ttl: 300s

# 分布式锁配置
distributed_lock:
  enabled: true
  redis_key_prefix: "lock:"

log:
  level: "debug"