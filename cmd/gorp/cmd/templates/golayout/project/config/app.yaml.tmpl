# 应用配置
# 中文说明：
# - 使用 gorp 框架统一配置格式；
# - 支持 noop 模式，单体阶段零依赖。

app:
  name: {{.Name}}
  env: dev
  debug: true
  address: :8080

# 服务器配置
server:
  http:
    addr: :8080
    mode: debug  # debug, release, test

# 数据库配置（单体阶段使用 sqlite）
database:
  driver: sqlite
  dsn: {{.Name}}.db

# 日志配置
log:
  level: debug
  format: console  # console, json

# tracing 配置
tracing:
{{- if .IsMicroserviceMode }}
  # 微服务模式：默认启用 tracing
  enabled: true
  backend: otel
  service_name: {{.Name}}
  otel:
    endpoint: localhost:4317
  sampling_rate: 1.0
{{- else }}
  # 单体/Gin-first 模式：关闭；需要时再切到 otel
  enabled: false
  backend: otel
  service_name: {{.Name}}
  otel:
    endpoint: localhost:4317
  sampling_rate: 1.0
{{- end }}

# metadata 传播配置
metadata:
{{- if .IsMicroserviceMode }}
  # 微服务模式：默认启用 metadata 传播
  enabled: true
  backend: default
  propagate_prefix:
    - x-md-
{{- else }}
  # 单体/Gin-first 模式：关闭；需要时再启用
  enabled: false
  backend: default
  propagate_prefix:
    - x-md-
{{- end }}

# 治理覆盖配置
# - mode 由 cmd/app/main.go 中的治理模式决定，通常不需要在这里重复声明
# - disable 用于显式关闭某个默认治理件
# - providers 用于显式替换默认 provider backend
governance:
{{- if .IsMicroserviceMode }}
  # 微服务模式：自动启用 tracing/selector/serviceauth/circuitbreaker
  disable: []
  providers:
    tracing: otel
    selector: p2c_ewma
    serviceauth: token
    circuitbreaker: sentinel
{{- else }}
  disable: []
  providers: {}
  # 示例：
  # disable:
  #   - tracing
  #   - selector
  # providers:
  #   serviceauth: mtls
  #   tracing: noop
{{- end }}

# service_auth 配置
service_auth:
{{- if .IsMicroserviceMode }}
  # 微服务模式：默认启用服务间认证
  enabled: true
  backend: token
  token:
    secret: change-me-in-production
    issuer: {{.Name}}
    audience: ""
    expiry: 3600
  allowed_services: []
{{- else }}
  # 单体/Gin-first 模式：关闭；需要服务间调用时再启用
  enabled: false
  backend: token
  token:
    secret: change-me-in-production
    issuer: {{.Name}}
    audience: ""
    expiry: 3600
  allowed_services: []
{{- end }}

# circuit_breaker 配置
circuit_breaker:
{{- if .IsMicroserviceMode }}
  # 微服务模式：默认启用熔断
  enabled: true
  backend: sentinel
  sentinel:
    strategy: error_count
    threshold: 50
    retry_timeout_ms: 5000
{{- else }}
  # 单体/Gin-first 模式：关闭
  enabled: false
  backend: sentinel
{{- end }}

# selector 配置
selector:
{{- if .IsMicroserviceMode }}
  # 微服务模式：默认启用 P2C 选择器
  enabled: true
  backend: p2c_ewma
{{- else }}
  # 单体/Gin-first 模式：关闭
  enabled: false
  backend: random
{{- end }}

# discovery 配置
discovery:
{{- if .IsMicroserviceMode }}
  # 微服务模式：默认启用服务发现
  enabled: true
  backend: etcd
  etcd:
    endpoints: ["localhost:2379"]
{{- else }}
  # 单体/Gin-first 模式：关闭
  enabled: false
  backend: noop
{{- end }}

# 业务 JWT 配置（已预留接入位）
auth:
  jwt:
    secret: change-me-in-production
    issuer: {{.Name}}
    audience: ""

# Redis 配置（作为可选接入位，不要求本地必须可用）
redis:
  addr: 127.0.0.1:6379
  password: ""
  db: 0

# message_queue 配置（关闭；需要异步消息时再启用 redis）
message_queue:
  enabled: false
  backend: redis
  redis:
    addr: 127.0.0.1:6379
    password: ""
    db: 0
  max_retry: 3

# distributed_lock 配置（关闭；需要任务防重/互斥时再启用 redis）
distributed_lock:
  enabled: false
  backend: redis
  redis:
    addr: 127.0.0.1:6379
    password: ""
    db: 0
  key_prefix: lock:

# Cache 配置（优先使用 memory，避免本地单服务起步强依赖 Redis）
cache:
  driver: memory
