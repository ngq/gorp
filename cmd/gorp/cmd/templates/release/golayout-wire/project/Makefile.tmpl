# {{.ProjectName}}

.PHONY: build run test tidy clean

APP_NAME := {{.ProjectName}}

# 构建
build:
	go build -o bin/$(APP_NAME) ./cmd/app

# 运行（直接通过项目 main 入口启动）
run:
	go run ./cmd/app

# 测试
test:
	go test -v -race ./...

# 清理
clean:
	rm -rf bin/

# 整理依赖
tidy:
	go mod tidy

# Docker 构建
docker:
	docker build -t $(APP_NAME):latest .

# Docker 运行
docker-run:
	docker run -p 8080:8080 $(APP_NAME):latest