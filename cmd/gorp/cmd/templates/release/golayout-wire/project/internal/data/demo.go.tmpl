package data

import (
	"context"
	"time"

	"{{.ModuleName}}/internal/biz"

	"gorm.io/gorm"
)

// DemoPO Demo 持久化对象。
type DemoPO struct {
	ID        uint      `gorm:"primaryKey"`
	Name      string    `gorm:"size:255"`
	CreatedAt time.Time `gorm:"autoCreateTime"`
	UpdatedAt time.Time `gorm:"autoUpdateTime"`
}

// TableName 表名。
func (DemoPO) TableName() string {
	return "demos"
}

// ToEntity 转换为领域实体。
func (po *DemoPO) ToEntity() *biz.Demo {
	return &biz.Demo{
		ID:        po.ID,
		Name:      po.Name,
		CreatedAt: po.CreatedAt,
		UpdatedAt: po.UpdatedAt,
	}
}

// ToPO 领域实体转换为 PO。
func ToPO(demo *biz.Demo) *DemoPO {
	return &DemoPO{
		ID:        demo.ID,
		Name:      demo.Name,
		CreatedAt: demo.CreatedAt,
		UpdatedAt: demo.UpdatedAt,
	}
}

// demoRepo 实现 biz.DemoRepository 接口。
type demoRepo struct {
	data *Data
}

// NewDemoRepo 创建 Demo 仓储。
func NewDemoRepo(data *Data) biz.DemoRepository {
	return &demoRepo{data: data}
}

// Create 创建。
func (r *demoRepo) Create(ctx context.Context, demo *biz.Demo) error {
	po := ToPO(demo)
	return r.data.DB().(*gorm.DB).WithContext(ctx).Create(po).Error
}

// GetByID 根据 ID 获取。
func (r *demoRepo) GetByID(ctx context.Context, id uint) (*biz.Demo, error) {
	var po DemoPO
	if err := r.data.DB().(*gorm.DB).WithContext(ctx).First(&po, id).Error; err != nil {
		return nil, err
	}
	return po.ToEntity(), nil
}

// List 获取列表。
func (r *demoRepo) List(ctx context.Context, page, pageSize int) ([]*biz.Demo, int64, error) {
	var pos []DemoPO
	var total int64

	db := r.data.DB().(*gorm.DB).WithContext(ctx).Model(&DemoPO{})
	if err := db.Count(&total).Error; err != nil {
		return nil, 0, err
	}

	offset := (page - 1) * pageSize
	if err := db.Offset(offset).Limit(pageSize).Find(&pos).Error; err != nil {
		return nil, 0, err
	}

	demos := make([]*biz.Demo, len(pos))
	for i, po := range pos {
		demos[i] = po.ToEntity()
	}

	return demos, total, nil
}

// Update 更新。
func (r *demoRepo) Update(ctx context.Context, demo *biz.Demo) error {
	po := ToPO(demo)
	return r.data.DB().(*gorm.DB).WithContext(ctx).Save(po).Error
}

// Delete 删除。
func (r *demoRepo) Delete(ctx context.Context, id uint) error {
	return r.data.DB().(*gorm.DB).WithContext(ctx).Delete(&DemoPO{}, id).Error
}