package main

import (
	"fmt"
	"os"

	apphttp "{{.Module}}/app/http"
	frameworkbootstrap "{{.FrameworkModule}}/framework/bootstrap"
)

// main 是 starter 项目的默认入口。
func main() {
	if err := frameworkbootstrap.BootHTTPService("{{.Name}}", frameworkbootstrap.HTTPServiceOptions{}, nil, setup); err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
}

func setup(rt *frameworkbootstrap.HTTPServiceRuntime) error {
	apphttp.RegisterRoutes(rt.Engine)
	return nil
}
