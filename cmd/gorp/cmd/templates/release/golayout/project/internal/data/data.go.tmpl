// Package data 数据访问层
//
// 中文说明：
// - 负责数据库、缓存等数据存储的访问；
// - 实现 internal/biz 中定义的 Repository 接口；
// - 使用框架提供的 ORM 能力（GORM/SQLX/Ent 可选）。
package data

import (
	"{{.FrameworkModule}}/framework/contract"
)

// Data 数据访问层聚合。
//
// 中文说明：
// - 封装数据库连接、缓存客户端等基础设施；
// - 提供给 Repository 使用；
// - 通过容器获取框架提供的 ORM 实例。
type Data struct {
	db  interface{} // GORM DB 或 SQLX DB 或 Ent Client
	c   contract.Container
}

// NewData 创建数据访问层。
//
// 中文说明：
// - 从容器获取 ORM 实例；
// - 支持多种后端：GORM / SQLX / Ent；
// - 单体阶段使用 sqlite，微服务阶段切换 MySQL/PostgreSQL。
func NewData(c contract.Container) *Data {
	return &Data{c: c}
}

// DB 获取数据库连接。
func (d *Data) DB() interface{} {
	if d.db != nil {
		return d.db
	}
	// 尝试从容器获取 GORM
	if gormAny, err := d.c.Make(contract.GormKey); err == nil {
		d.db = gormAny
		return d.db
	}
	// 尝试从容器获取 SQLX
	if sqlxAny, err := d.c.Make(contract.SQLXKey); err == nil {
		d.db = sqlxAny
		return d.db
	}
	return nil
}