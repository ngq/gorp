// Package service 服务层
//
// 中文说明：
// - 实现 HTTP/gRPC 接口；
// - 调用 biz 层的用例；
// - 负责请求/响应的转换。
package service

import (
	"net/http"
	"strconv"

	"{{.ModuleName}}/internal/biz"

	"github.com/gin-gonic/gin"
)

// Services 服务层聚合。
type Services struct {
	Demo *DemoService
}

// NewServices 创建服务层。
func NewServices(biz *biz.Biz) *Services {
	return &Services{
		Demo: &DemoService{uc: biz.Demo},
	}
}

// DemoService Demo 服务。
type DemoService struct {
	uc *biz.DemoUseCase
}

// CreateDemoRequest 创建 Demo 请求。
type CreateDemoRequest struct {
	Name string `json:"name" binding:"required"`
}

// UpdateDemoRequest 更新 Demo 请求。
type UpdateDemoRequest struct {
	Name string `json:"name" binding:"required"`
}

// DemoResponse Demo 响应。
type DemoResponse struct {
	ID        uint   `json:"id"`
	Name      string `json:"name"`
	CreatedAt string `json:"created_at"`
	UpdatedAt string `json:"updated_at"`
}

// ListDemoResponse Demo 列表响应。
type ListDemoResponse struct {
	Items []*DemoResponse `json:"items"`
	Total int64           `json:"total"`
	Page  int             `json:"page"`
	Size  int             `json:"size"`
}

// Create 创建 Demo。
func (s *DemoService) Create(c *gin.Context) {
	var req CreateDemoRequest
	if err := c.ShouldBindJSON(&req); err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": err.Error()})
		return
	}

	demo, err := s.uc.Create(c.Request.Context(), req.Name)
	if err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"error": err.Error()})
		return
	}

	c.JSON(http.StatusCreated, toDemoResponse(demo))
}

// GetByID 获取 Demo。
func (s *DemoService) GetByID(c *gin.Context) {
	id, err := strconv.ParseUint(c.Param("id"), 10, 64)
	if err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": "invalid id"})
		return
	}

	demo, err := s.uc.GetByID(c.Request.Context(), uint(id))
	if err != nil {
		c.JSON(http.StatusNotFound, gin.H{"error": "not found"})
		return
	}

	c.JSON(http.StatusOK, toDemoResponse(demo))
}

// List 获取 Demo 列表。
func (s *DemoService) List(c *gin.Context) {
	page, _ := strconv.Atoi(c.DefaultQuery("page", "1"))
	pageSize, _ := strconv.Atoi(c.DefaultQuery("size", "10"))

	if page < 1 {
		page = 1
	}
	if pageSize < 1 || pageSize > 100 {
		pageSize = 10
	}

	demos, total, err := s.uc.List(c.Request.Context(), page, pageSize)
	if err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"error": err.Error()})
		return
	}

	items := make([]*DemoResponse, len(demos))
	for i, demo := range demos {
		items[i] = toDemoResponse(demo)
	}

	c.JSON(http.StatusOK, &ListDemoResponse{
		Items: items,
		Total: total,
		Page:  page,
		Size:  pageSize,
	})
}

// Update 更新 Demo。
func (s *DemoService) Update(c *gin.Context) {
	id, err := strconv.ParseUint(c.Param("id"), 10, 64)
	if err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": "invalid id"})
		return
	}

	var req UpdateDemoRequest
	if err := c.ShouldBindJSON(&req); err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": err.Error()})
		return
	}

	demo, err := s.uc.Update(c.Request.Context(), uint(id), req.Name)
	if err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"error": err.Error()})
		return
	}

	c.JSON(http.StatusOK, toDemoResponse(demo))
}

// Delete 删除 Demo。
func (s *DemoService) Delete(c *gin.Context) {
	id, err := strconv.ParseUint(c.Param("id"), 10, 64)
	if err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": "invalid id"})
		return
	}

	if err := s.uc.Delete(c.Request.Context(), uint(id)); err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"error": err.Error()})
		return
	}

	c.Status(http.StatusNoContent)
}

// toDemoResponse 转换为响应。
func toDemoResponse(demo *biz.Demo) *DemoResponse {
	return &DemoResponse{
		ID:        demo.ID,
		Name:      demo.Name,
		CreatedAt: demo.CreatedAt.Format("2006-01-02 15:04:05"),
		UpdatedAt: demo.UpdatedAt.Format("2006-01-02 15:04:05"),
	}
}