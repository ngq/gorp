# Service 配置
apiVersion: v1
kind: Service
metadata:
  name: {{.KubernetesName}}
  labels:
    app.kubernetes.io/name: {{.KubernetesName}}
spec:
  type: ClusterIP
  ports:
    - name: http
      port: 80
      targetPort: http
      protocol: TCP
  selector:
    app.kubernetes.io/name: {{.KubernetesName}}
