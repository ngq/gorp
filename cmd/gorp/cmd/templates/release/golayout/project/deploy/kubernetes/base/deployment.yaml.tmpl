# Deployment 基础配置
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{.KubernetesName}}
  labels:
    app.kubernetes.io/name: {{.KubernetesName}}
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: {{.KubernetesName}}
  template:
    metadata:
      labels:
        app.kubernetes.io/name: {{.KubernetesName}}
      annotations:
        prometheus.io/scrape: "true"
        prometheus.io/port: "8080"
        prometheus.io/path: "/metrics"
    spec:
      containers:
        - name: {{.KubernetesName}}
          image: your-registry/{{.KubernetesName}}:latest
          imagePullPolicy: IfNotPresent
          ports:
            - name: http
              containerPort: 8080
              protocol: TCP
          envFrom:
            - configMapRef:
                name: {{.KubernetesConfigMapName}}
            - secretRef:
                name: {{.KubernetesSecretName}}
          resources:
            requests:
              cpu: "100m"
              memory: "128Mi"
            limits:
              cpu: "500m"
              memory: "512Mi"
          livenessProbe:
            httpGet:
              path: /healthz
              port: http
            initialDelaySeconds: 10
            periodSeconds: 10
            timeoutSeconds: 5
            failureThreshold: 3
          readinessProbe:
            httpGet:
              path: /healthz
              port: http
            initialDelaySeconds: 5
            periodSeconds: 10
            timeoutSeconds: 5
            failureThreshold: 3
      terminationGracePeriodSeconds: 30
