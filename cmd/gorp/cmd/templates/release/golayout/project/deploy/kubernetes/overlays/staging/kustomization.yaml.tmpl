# 预发布环境 Kustomization
apiVersion: kustomize.config.k8s.io/v1beta1
kind: Kustomization

namespace: {{.KubernetesNamespaceStaging}}

resources:
  - ../../base

images:
  - name: your-registry/{{.KubernetesName}}
    newName: your-registry/{{.KubernetesName}}
    newTag: staging

configMapGenerator:
  - name: {{.KubernetesConfigMapName}}
    behavior: merge
    literals:
      - APP_ENV=staging
      - LOG_LEVEL=info
      - LOG_FORMAT=json

patches:
  - path: deployment-patch.yaml
