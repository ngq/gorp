# 应用配置
# 中文说明：
# - 使用 gorp 框架统一配置格式；
# - 默认按 framework-native 主线生成，兼顾单体起步与后续渐进演进。

service:
  name: {{.Name}}
  namespace: default
  env: dev

app:
  name: {{.Name}}
  env: dev
  debug: true
  address: :8080

server:
  http:
    addr: :8080

# 如需切换外部配置源、服务发现、selector 或 RPC 传输，再按需显式开启
# configsource:
#   type: local
#
# discovery:
#   type: consul
#   service:
#     name: {{.Name}}
#     addr: 127.0.0.1
#     port: 8080
#
# selector:
#   algorithm: p2c_ewma
#
# rpc:
#   mode: grpc
#   timeout_ms: 30000

# 数据库配置（默认使用本地 sqlite，保证模板开箱即跑）
database:
  driver: sqlite
  dsn: {{.Name}}.db

# 日志配置
log:
  level: debug
  format: console

tracing:
  enabled: false
  service:
    name: {{.Name}}

metadata:
  propagate_prefix:
    - x-md-
  constant_metadata: {}

# 治理覆盖配置
# - mode 默认由 cmd/app/main.go 中的 gorp.WithMicroserviceMode() 决定
# - 只在需要关闭默认治理件或替换 provider 时再写这里
governance:
  disable: []
  providers: {}
  # 示例：
  # disable:
  #   - tracing
  # providers:
  #   serviceauth: mtls

serviceauth:
  mode: noop
