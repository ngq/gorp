package main

import (
	"fmt"
	"os"

	apphttp "{{.ModuleName}}/app/http"
	"{{.ModuleName}}/internal/biz"
	"{{.ModuleName}}/internal/data"
	"{{.ModuleName}}/internal/service"
	"{{.FrameworkModule}}"
{{- if .IsGinFirstMode }}
	transportcontract "{{.FrameworkModule}}/framework/contract/transport"
{{- end }}
)

// main 是项目主入口。
//
// 中文说明：
// - 用户日常开发时，直接 `go run ./cmd/app` 或 IDE 调试即可启动 HTTP 服务；
// - 使用框架统一入口 gorp，简化导入；
// - 默认主线直接走 typed runtime + direct constructor，不要求先理解 ServiceProvider / ExtraProviders。
func main() {
	if err := gorp.Run(
		"{{.Name}}",
		gorp.HTTP(),
{{- if .IsMicroserviceMode }}
		gorp.WithMicroserviceMode(),
{{- else if .IsGinFirstMode }}
		gorp.WithGinFirstMode(),
{{- else }}
		gorp.WithMonolithMode(),
{{- end }}
		gorp.WithMigrate(migrate),
		gorp.WithSetup(setup),
	); err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
}

func migrate(rt *gorp.HTTPRuntime) error {
	if rt == nil || rt.DB == nil {
		return nil
	}
	return rt.DB.AutoMigrate(&data.DemoPO{})
}

func setup(rt *gorp.HTTPRuntime) error {
	d := data.NewData(rt.DB)
	b := biz.NewBiz(data.NewDemoRepo(d))
	svc := service.NewServices(b)
{{- if .IsGinFirstMode }}

	// Gin-first 模式：传递 HTTP 服务给路由注册函数
	httpSvc, err := rt.Container.Make(transportcontract.HTTPKey)
	if err != nil {
		return err
	}
	apphttp.RegisterRoutes(httpSvc.(transportcontract.HTTP), svc)
{{- else }}
	apphttp.RegisterRoutes(rt.Router, svc)
{{- end }}
	return nil
}
