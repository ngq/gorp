package server

import (
	"net/http"
	"strconv"

	"{{.ModuleName}}/services/user/internal/service"

	"github.com/gin-gonic/gin"
	ginprovider "{{.FrameworkModule}}/framework/provider/gin"
)

// HTTPServer 用户 HTTP 入口。
type HTTPServer struct {
	user *service.UserService
}

// NewHTTPServer 创建用户 HTTP 入口。
func NewHTTPServer(services *service.Services) *HTTPServer {
	return &HTTPServer{user: services.User}
}

// RegisterRoutes 注册用户服务路由。
func (s *HTTPServer) RegisterRoutes(r *gin.Engine) {
	api := r.Group("/api/v1/users")
	{
		api.GET("", s.List)
		api.GET("/:id", s.GetByID)
		api.POST("", s.Create)
		api.DELETE("/:id", s.Delete)
	}
}

// List 获取用户列表。
func (s *HTTPServer) List(c *gin.Context) {
	page, _ := strconv.Atoi(c.DefaultQuery("page", "1"))
	size, _ := strconv.Atoi(c.DefaultQuery("size", "10"))

	items, total, err := s.user.List(c.Request.Context(), page, size)
	if err != nil {
		ginprovider.InternalError(c, err.Error())
		return
	}

	ginprovider.Success(c, gin.H{"items": items, "total": total, "page": page, "size": size})
}

// GetByID 获取单个用户。
func (s *HTTPServer) GetByID(c *gin.Context) {
	id, err := strconv.ParseUint(c.Param("id"), 10, 64)
	if err != nil {
		ginprovider.BadRequest(c, "invalid id")
		return
	}

	user, err := s.user.GetByID(c.Request.Context(), uint(id))
	if err != nil {
		ginprovider.NotFound(c, "user not found")
		return
	}

	ginprovider.Success(c, user)
}

// Create 创建用户。
func (s *HTTPServer) Create(c *gin.Context) {
	var req service.CreateUserRequest
	if err := c.ShouldBindJSON(&req); err != nil {
		ginprovider.BadRequest(c, err.Error())
		return
	}

	user, err := s.user.Create(c.Request.Context(), req)
	if err != nil {
		ginprovider.InternalError(c, err.Error())
		return
	}

	ginprovider.SuccessWithStatus(c, http.StatusCreated, user)
}

// Delete 删除用户。
func (s *HTTPServer) Delete(c *gin.Context) {
	id, err := strconv.ParseUint(c.Param("id"), 10, 64)
	if err != nil {
		ginprovider.BadRequest(c, "invalid id")
		return
	}

	if err := s.user.Delete(c.Request.Context(), uint(id)); err != nil {
		ginprovider.InternalError(c, err.Error())
		return
	}

	c.Status(http.StatusNoContent)
}
