app:
  name: user-service
  env: development
  address: ":8081"

service:
  name: user-service

rpc:
  mode: grpc
  grpc:
    address: ":9081"

server:
  http:
    addr: ":8081"
    mode: debug

database:
  driver: sqlite
  dsn: user.db

redis:
  addr: "${REDIS_ADDR:localhost:6379}"
  password: ""
  db: 0

log:
  level: debug

tracing:
  enabled: true
  backend: stdout
  otel:
    endpoint: "${JAEGER_ENDPOINT:localhost:4317}"
  sampling_rate: 1.0

metadata:
  enabled: true
  propagate_prefix:
    - x-md-

service_auth:
  mode: token
  token:
    secret: "change-me-in-production"
    issuer: "user-service"
    audience: "internal"
    expiry: 3600
  allowed_services:
    - order-service

cache:
  driver: memory

message_queue:
  enabled: false
  backend: redis
  redis:
    addr: "${REDIS_ADDR:localhost:6379}"
    password: ""
    db: 0

