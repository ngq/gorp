package server

import (
	"net/http"
	"strconv"

	"{{.ModuleName}}/services/order/internal/service"

	"github.com/gin-gonic/gin"
)

// HTTPServer 订单 HTTP 入口。
type HTTPServer struct {
	order *service.OrderService
}

// NewHTTPServer 创建订单 HTTP 入口。
func NewHTTPServer(services *service.Services) *HTTPServer {
	return &HTTPServer{order: services.Order}
}

// RegisterRoutes 注册订单服务路由。
func (s *HTTPServer) RegisterRoutes(r *gin.Engine) {
	api := r.Group("/api/v1/orders")
	{
		api.GET("", s.List)
		api.GET("/:id", s.GetByID)
		api.POST("", s.Create)
		api.DELETE("/:id", s.Delete)
		api.GET("/:id/user", s.GetOrderUser)
		api.POST("/:id/lock-demo", s.LockOrderDemo)
	}
}

// List 获取订单列表。
func (s *HTTPServer) List(c *gin.Context) {
	page, _ := strconv.Atoi(c.DefaultQuery("page", "1"))
	size, _ := strconv.Atoi(c.DefaultQuery("size", "10"))

	items, total, err := s.order.List(c.Request.Context(), page, size)
	if err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"error": err.Error()})
		return
	}

	c.JSON(http.StatusOK, gin.H{"items": items, "total": total, "page": page, "size": size})
}

// GetByID 获取单个订单。
func (s *HTTPServer) GetByID(c *gin.Context) {
	id, err := strconv.ParseUint(c.Param("id"), 10, 64)
	if err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": "invalid id"})
		return
	}

	order, err := s.order.GetByID(c.Request.Context(), uint(id))
	if err != nil {
		c.JSON(http.StatusNotFound, gin.H{"error": "order not found"})
		return
	}

	c.JSON(http.StatusOK, order)
}

// Create 创建订单。
func (s *HTTPServer) Create(c *gin.Context) {
	var req service.CreateOrderRequest
	if err := c.ShouldBindJSON(&req); err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": err.Error()})
		return
	}

	order, err := s.order.Create(c.Request.Context(), req)
	if err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"error": err.Error()})
		return
	}

	c.JSON(http.StatusCreated, order)
}

// Delete 删除订单。
func (s *HTTPServer) Delete(c *gin.Context) {
	id, err := strconv.ParseUint(c.Param("id"), 10, 64)
	if err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": "invalid id"})
		return
	}

	if err := s.order.Delete(c.Request.Context(), uint(id)); err != nil {
		c.JSON(http.StatusInternalServerError, gin.H{"error": err.Error()})
		return
	}

	c.Status(http.StatusNoContent)
}

// GetOrderUser 通过 user-service 查询订单用户。
func (s *HTTPServer) GetOrderUser(c *gin.Context) {
	id, err := strconv.ParseUint(c.Param("id"), 10, 64)
	if err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": "invalid id"})
		return
	}

	resp, err := s.order.GetOrderUser(c.Request.Context(), uint(id))
	if err != nil {
		c.JSON(http.StatusBadGateway, gin.H{"error": err.Error()})
		return
	}

	c.JSON(http.StatusOK, resp)
}

// LockOrderDemo 验证分布式锁能力。
func (s *HTTPServer) LockOrderDemo(c *gin.Context) {
	id, err := strconv.ParseUint(c.Param("id"), 10, 64)
	if err != nil {
		c.JSON(http.StatusBadRequest, gin.H{"error": "invalid id"})
		return
	}

	resp, err := s.order.LockOrderDemo(c.Request.Context(), uint(id))
	if err != nil {
		c.JSON(http.StatusConflict, gin.H{"error": err.Error()})
		return
	}

	c.JSON(http.StatusOK, resp)
}
