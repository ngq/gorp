package http

import (
	"{{.ModuleName}}/services/order/internal/server/http/handler"
	"{{.ModuleName}}/services/order/internal/service"

{{- if .IsGinHTTPMode }}
	ginprovider "{{.FrameworkModule}}/framework/provider/gin"
	transportcontract "{{.FrameworkModule}}/framework/contract/transport"

	"github.com/gin-gonic/gin"
{{- else }}
	gorp "{{.FrameworkModule}}"
{{- end }}
)

// RegisterRoutes 注册 HTTP 路由。
//
// 中文说明：
// - Gin-first 模式：直接使用原生 Gin Engine 注册路由；
// - 抽象契约模式：使用 gorp.Router 抽象接口；
func RegisterRoutes(
{{- if .IsGinHTTPMode }}
	httpSvc transportcontract.HTTP,
{{- else }}
	r gorp.Router,
{{- end }}
	services *service.Services,
) {
{{- if .IsGinHTTPMode }}
	// Gin-first 模式：获取原生 Gin Engine
	engine, ok := ginprovider.NativeEngine(httpSvc)
	if !ok {
		panic("failed to get native gin engine")
	}

	orderHandler := handler.NewOrderHandler(services.Order)

	api := engine.Group("/api/v1/orders")
	{
		api.GET("", orderHandler.List)
		api.GET("/:id", orderHandler.GetByID)
		api.POST("", orderHandler.Create)
		api.DELETE("/:id", orderHandler.Delete)
		api.GET("/:id/user", orderHandler.GetOrderUser)
		api.POST("/:id/lock-demo", orderHandler.LockOrderDemo)
	}
{{- else }}
	orderHandler := handler.NewOrderHandler(services.Order)

	api := r.Group("/api/v1/orders")
	{
		api.GET("", orderHandler.List)
		api.GET("/:id", orderHandler.GetByID)
		api.POST("", orderHandler.Create)
		api.DELETE("/:id", orderHandler.Delete)
		api.GET("/:id/user", orderHandler.GetOrderUser)
		api.POST("/:id/lock-demo", orderHandler.LockOrderDemo)
	}
{{- end }}
}
