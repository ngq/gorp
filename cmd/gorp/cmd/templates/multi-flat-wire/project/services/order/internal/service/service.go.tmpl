// Package service 服务层。
package service

import (
	"context"
	"fmt"
	"time"

	userv1 "{{.ModuleName}}/proto/user/v1"
	"{{.ModuleName}}/services/order/internal/biz"
	"{{.ModuleName}}/services/order/internal/data"

	"github.com/ngq/gorp/framework/contract"
	"gorm.io/gorm"
)

// Services 服务层聚合。
type Services struct {
	Order *OrderService
}

// NewServices 创建服务层。
func NewServices(db *gorm.DB, userConnFactory contract.GRPCConnFactory, dlock contract.DistributedLock) *Services {
	orderRepo := data.NewOrderRepo(db)
	orderUC := biz.NewOrderUseCase(orderRepo)
	return &Services{
		Order: &OrderService{uc: orderUC, userConnFactory: userConnFactory, dlock: dlock},
	}
}

// OrderService 订单服务。
type OrderService struct {
	uc              *biz.OrderUseCase
	userConnFactory contract.GRPCConnFactory
	dlock           contract.DistributedLock
}

// CreateOrderRequest 创建订单请求。
type CreateOrderRequest struct {
	UserID      uint    `json:"user_id" binding:"required"`
	ProductID   uint    `json:"product_id" binding:"required"`
	ProductName string  `json:"product_name" binding:"required"`
	Quantity    int     `json:"quantity" binding:"required"`
	TotalPrice  float64 `json:"total_price" binding:"required"`
}

// OrderResponse 订单响应。
type OrderResponse struct {
	ID          uint    `json:"id"`
	UserID      uint    `json:"user_id"`
	ProductID   uint    `json:"product_id"`
	ProductName string  `json:"product_name"`
	Quantity    int     `json:"quantity"`
	TotalPrice  float64 `json:"total_price"`
	Status      string  `json:"status"`
	CreatedAt   int64   `json:"created_at"`
	UpdatedAt   int64   `json:"updated_at"`
}

// RemoteUserResponse 远程用户验证响应。
type RemoteUserResponse struct {
	ID                uint64 `json:"id"`
	Username          string `json:"username"`
	Email             string `json:"email"`
	TraceID           string `json:"trace_id"`
	RequestID         string `json:"request_id"`
	MetadataDemo      string `json:"metadata_demo"`
	CallerServiceName string `json:"caller_service_name"`
}

// LockDemoResponse 分布式锁样板响应。
type LockDemoResponse struct {
	Key     string `json:"key"`
	Success bool   `json:"success"`
}

// List 获取订单列表。
func (s *OrderService) List(ctx context.Context, page, size int) ([]OrderResponse, int64, error) {
	orders, total, err := s.uc.List(ctx, page, size)
	if err != nil {
		return nil, 0, err
	}

	items := make([]OrderResponse, len(orders))
	for i, o := range orders {
		items[i] = toOrderResponse(o)
	}
	return items, total, nil
}

// GetByID 获取单个订单。
func (s *OrderService) GetByID(ctx context.Context, id uint) (*OrderResponse, error) {
	order, err := s.uc.GetByID(ctx, id)
	if err != nil {
		return nil, err
	}
	resp := toOrderResponse(order)
	return &resp, nil
}

// Create 创建订单。
func (s *OrderService) Create(ctx context.Context, req CreateOrderRequest) (*OrderResponse, error) {
	order, err := s.uc.Create(ctx, req.UserID, req.ProductID, req.ProductName, req.Quantity, req.TotalPrice)
	if err != nil {
		return nil, err
	}
	resp := toOrderResponse(order)
	return &resp, nil
}

// Delete 删除订单。
func (s *OrderService) Delete(ctx context.Context, id uint) error {
	return s.uc.Delete(ctx, id)
}

// GetOrderUser 通过 Proto-first gRPC 访问 user-service，验证 tracing/metadata/service_auth 闭环。
func (s *OrderService) GetOrderUser(ctx context.Context, id uint) (*RemoteUserResponse, error) {
	order, err := s.uc.GetByID(ctx, id)
	if err != nil {
		return nil, err
	}

	ctx = contract.AppendToClientContext(ctx, "x-md-demo", "hello-metadata")
	conn, err := s.userConnFactory.Conn(ctx, "user-service")
	if err != nil {
		return nil, fmt.Errorf("dial user-service failed: %w", err)
	}

	resp, err := userv1.NewUserServiceClient(conn).GetUser(ctx, &userv1.GetUserRequest{Id: uint64(order.UserID)})
	if err != nil {
		return nil, fmt.Errorf("call user-service failed: %w", err)
	}

	return &RemoteUserResponse{
		ID:                resp.GetId(),
		Username:          resp.GetUsername(),
		Email:             resp.GetEmail(),
		TraceID:           resp.GetTraceId(),
		RequestID:         resp.GetRequestId(),
		MetadataDemo:      resp.GetMetadataDemo(),
		CallerServiceName: resp.GetCallerServiceName(),
	}, nil
}

// LockOrderDemo 通过最小竞争锁样板验证分布式锁能力。
func (s *OrderService) LockOrderDemo(ctx context.Context, id uint) (*LockDemoResponse, error) {
	key := fmt.Sprintf("order:%d", id)
	if err := s.dlock.WithLock(ctx, key, 3*time.Second, func() error {
		return nil
	}); err != nil {
		return nil, err
	}
	return &LockDemoResponse{Key: key, Success: true}, nil
}

// toOrderResponse 转换为响应格式。
func toOrderResponse(o *biz.Order) OrderResponse {
	return OrderResponse{
		ID:          o.ID,
		UserID:      o.UserID,
		ProductID:   o.ProductID,
		ProductName: o.ProductName,
		Quantity:    o.Quantity,
		TotalPrice:  o.TotalPrice,
		Status:      o.Status,
		CreatedAt:   o.CreatedAt.Unix(),
		UpdatedAt:   o.UpdatedAt.Unix(),
	}
}
