package handler

import (
	"net/http"
	"strconv"

	"github.com/gin-gonic/gin"
	gorp "{{.FrameworkModule}}"
	"{{.ModuleName}}/services/order/internal/server/http/request"
	"{{.ModuleName}}/services/order/internal/server/http/response"
	"{{.ModuleName}}/services/order/internal/service"
)

type OrderHandler struct {
	order *service.OrderService
}

func NewOrderHandler(order *service.OrderService) *OrderHandler {
	return &OrderHandler{order: order}
}

func (h *OrderHandler) List(c *gin.Context) {
	page, _ := strconv.Atoi(c.DefaultQuery("page", "1"))
	size, _ := strconv.Atoi(c.DefaultQuery("size", "10"))

	items, total, err := h.order.List(c.Request.Context(), page, size)
	if err != nil {
		gorp.GinError(c, err)
		return
	}

	respItems := make([]response.Order, len(items))
	for i, item := range items {
		respItems[i] = response.Order{
			ID:          item.ID,
			UserID:      item.UserID,
			ProductID:   item.ProductID,
			ProductName: item.ProductName,
			Quantity:    item.Quantity,
			TotalPrice:  item.TotalPrice,
			Status:      item.Status,
			CreatedAt:   item.CreatedAt,
			UpdatedAt:   item.UpdatedAt,
		}
	}

	gorp.GinSuccess(c, response.OrderList{
		Items: respItems,
		Total: total,
		Page:  page,
		Size:  size,
	})
}

func (h *OrderHandler) GetByID(c *gin.Context) {
	id, err := strconv.ParseUint(c.Param("id"), 10, 64)
	if err != nil {
		gorp.GinBadRequest(c, "invalid id")
		return
	}

	order, err := h.order.GetByID(c.Request.Context(), uint(id))
	if err != nil {
		c.JSON(http.StatusNotFound, gin.H{"error": "order not found"})
		return
	}

	gorp.GinSuccess(c, response.Order{
		ID:          order.ID,
		UserID:      order.UserID,
		ProductID:   order.ProductID,
		ProductName: order.ProductName,
		Quantity:    order.Quantity,
		TotalPrice:  order.TotalPrice,
		Status:      order.Status,
		CreatedAt:   order.CreatedAt,
		UpdatedAt:   order.UpdatedAt,
	})
}

func (h *OrderHandler) Create(c *gin.Context) {
	var req request.CreateOrder
	if err := c.ShouldBindJSON(&req); err != nil {
		gorp.GinBadRequest(c, err.Error())
		return
	}

	order, err := h.order.Create(c.Request.Context(), service.CreateOrderRequest{
		UserID:      req.UserID,
		ProductID:   req.ProductID,
		ProductName: req.ProductName,
		Quantity:    req.Quantity,
		TotalPrice:  req.TotalPrice,
	})
	if err != nil {
		gorp.GinError(c, err)
		return
	}

	gorp.GinSuccessWithStatus(c, http.StatusCreated, response.Order{
		ID:          order.ID,
		UserID:      order.UserID,
		ProductID:   order.ProductID,
		ProductName: order.ProductName,
		Quantity:    order.Quantity,
		TotalPrice:  order.TotalPrice,
		Status:      order.Status,
		CreatedAt:   order.CreatedAt,
		UpdatedAt:   order.UpdatedAt,
	})
}

func (h *OrderHandler) Delete(c *gin.Context) {
	id, err := strconv.ParseUint(c.Param("id"), 10, 64)
	if err != nil {
		gorp.GinBadRequest(c, "invalid id")
		return
	}

	if err := h.order.Delete(c.Request.Context(), uint(id)); err != nil {
		gorp.GinError(c, err)
		return
	}

	c.Status(http.StatusNoContent)
}

func (h *OrderHandler) GetOrderUser(c *gin.Context) {
	id, err := strconv.ParseUint(c.Param("id"), 10, 64)
	if err != nil {
		gorp.GinBadRequest(c, "invalid id")
		return
	}

	resp, err := h.order.GetOrderUser(c.Request.Context(), uint(id))
	if err != nil {
		c.JSON(http.StatusBadGateway, gin.H{"error": err.Error()})
		return
	}

	gorp.GinSuccess(c, response.RemoteUser{
		ID:                resp.ID,
		Username:          resp.Username,
		Email:             resp.Email,
		TraceID:           resp.TraceID,
		RequestID:         resp.RequestID,
		MetadataDemo:      resp.MetadataDemo,
		CallerServiceName: resp.CallerServiceName,
	})
}

func (h *OrderHandler) LockOrderDemo(c *gin.Context) {
	id, err := strconv.ParseUint(c.Param("id"), 10, 64)
	if err != nil {
		gorp.GinBadRequest(c, "invalid id")
		return
	}

	resp, err := h.order.LockOrderDemo(c.Request.Context(), uint(id))
	if err != nil {
		c.JSON(http.StatusConflict, gin.H{"error": err.Error()})
		return
	}

	gorp.GinSuccess(c, response.LockDemo{
		Key:     resp.Key,
		Success: resp.Success,
	})
}