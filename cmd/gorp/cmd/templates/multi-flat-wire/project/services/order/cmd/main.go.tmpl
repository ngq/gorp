package main

import (
	"fmt"
	"os"

	orderdata "{{.ModuleName}}/services/order/internal/data"
	orderhttp "{{.ModuleName}}/services/order/internal/server/http"
	"{{.FrameworkModule}}"
{{- if .IsMicroGovernance }}
	_ "{{.ModuleName}}/shared" // 微服务治理组件统一导入
{{- end }}
{{- if .IsGinHTTPMode }}
	transportcontract "{{.FrameworkModule}}/framework/contract/transport"
{{- end }}
)

// main 是 order 服务的主入口。
func main() {
	if err := gorp.Run(
{{- if .IsMicroGovernance }}
		gorp.GRPC(),
		gorp.WithMicroGovernance(),
{{- else }}
		gorp.WithMonoGovernance(),
{{- end }}
{{- if .IsGinHTTPMode }}
		gorp.WithGinHTTPMode(),
{{- end }}
		gorp.WithMigrate(migrate),
		gorp.WithSetup(setup),
	); err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
}

func migrate(rt *gorp.HTTPRuntime) error {
	if rt == nil || rt.DB == nil {
		return nil
	}
	return rt.DB.AutoMigrate(&orderdata.OrderPO{})
}

func setup(rt *gorp.HTTPRuntime) error {
	if rt.DB == nil {
		return fmt.Errorf("order-service requires gorm database")
	}
	connFactory, err := gorp.MakeGRPCConnFactory(rt.Container)
	if err != nil {
		return err
	}
	dlock, err := gorp.MakeDistributedLock(rt.Container)
	if err != nil {
		return err
	}
	services, err := wireOrderServices(rt.DB, connFactory, dlock)
	if err != nil {
		return err
	}
{{- if .IsGinHTTPMode }}

	// Gin-first 模式：传递 HTTP 服务给路由注册函数
	httpSvc, err := rt.Container.Make(transportcontract.HTTPKey)
	if err != nil {
		return err
	}
	orderhttp.RegisterRoutes(httpSvc.(transportcontract.HTTP), services)
{{- else }}
	orderhttp.RegisterRoutes(rt.Router, services)
{{- end }}
	return nil
}
