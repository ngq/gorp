package main

import (
	"fmt"
	"os"

	"{{.FrameworkModule}}/framework/container"
	orderdata "{{.ModuleName}}/services/order/internal/data"
	orderhttp "{{.ModuleName}}/services/order/internal/server/http"
	"{{.FrameworkModule}}"
)

// main 是 order 服务的主入口。
func main() {
	if err := gorp.Run("order-service", gorp.HTTP(), gorp.WithMigrate(migrate), gorp.WithSetup(setup)); err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
}

func migrate(rt *gorp.HTTPRuntime) error {
	if rt == nil || rt.DB == nil {
		return nil
	}
	return rt.DB.AutoMigrate(&orderdata.OrderPO{})
}

func setup(rt *gorp.HTTPRuntime) error {
	if rt.DB == nil {
		return fmt.Errorf("order-service requires gorm database")
	}

	// 添加全局 gin 中间件（可选）
	// ginEngine, _ := container.MakeGinEngine(rt.Container)
	// ginEngine.Use(gorp.GinRequestIDMiddleware())
	// ginEngine.Use(gorp.GinTraceIDMiddleware())

	connFactory, err := gorp.MakeGRPCConnFactory(rt.Container)
	if err != nil {
		return err
	}
	dlock, err := gorp.MakeDistributedLock(rt.Container)
	if err != nil {
		return err
	}
	services, handlers, err := wireOrderServices(rt.DB, connFactory, dlock)
	if err != nil {
		return err
	}
	orderhttp.RegisterRoutes(rt.GinRouter, handlers)
	return nil
}