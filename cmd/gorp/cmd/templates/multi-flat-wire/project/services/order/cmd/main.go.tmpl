package main

import (
	"fmt"
	"os"

	orderdata "{{.ModuleName}}/services/order/internal/data"
	orderserver "{{.ModuleName}}/services/order/internal/server"
	frameworkbootstrap "{{.FrameworkModule}}/framework/bootstrap"
	frameworkcontainer "{{.FrameworkModule}}/framework/container"
)

// main 是 order 服务的主入口。
func main() {
	if err := frameworkbootstrap.BootHTTPService("order-service", frameworkbootstrap.HTTPServiceOptions{}, migrate, setup); err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
}

func migrate(rt *frameworkbootstrap.HTTPServiceRuntime) error {
	return frameworkbootstrap.AutoMigrateModels(rt, &orderdata.OrderPO{})
}

func setup(rt *frameworkbootstrap.HTTPServiceRuntime) error {
	if rt.DB == nil {
		return fmt.Errorf("order-service requires gorm database")
	}
	connFactory, err := frameworkcontainer.MakeGRPCConnFactory(rt.Container)
	if err != nil {
		return err
	}
	dlock, err := frameworkcontainer.MakeDistributedLock(rt.Container)
	if err != nil {
		return err
	}
	services, err := wireOrderServices(rt.DB, connFactory, dlock)
	if err != nil {
		return err
	}
	httpServer := orderserver.NewHTTPServer(services)
	httpServer.RegisterRoutes(rt.Engine)
	return nil
}
