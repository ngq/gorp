app:
  name: order-service
  env: dev
  address: ":8082"

service:
  name: order-service

rpc:
  mode: grpc
  grpc:
    address: ":9082"
    target: "127.0.0.1:9081"

server:
  http:
    addr: ":8082"
    mode: debug

database:
  driver: sqlite
  dsn: order.db

redis:
  addr: "${REDIS_ADDR:localhost:6379}"
  password: ""
  db: 0

log:
  level: debug

tracing:
{{- if .IsMicroserviceMode }}
  enabled: true
{{- else }}
  enabled: false
{{- end }}
  backend: otel
  service_name: order-service
  otel:
    endpoint: "${JAEGER_ENDPOINT:localhost:4317}"
  sampling_rate: 1.0

metadata:
{{- if .IsMicroserviceMode }}
  enabled: true
{{- else }}
  enabled: false
{{- end }}
  propagate_prefix:
    - x-md-

service_auth:
{{- if .IsMicroserviceMode }}
  mode: token
  token:
    secret: "change-me-in-production"
    issuer: "order-service"
    audience: "internal"
    expiry: 3600
  allowed_services:
    - user-service
{{- else }}
  mode: noop
  token:
    secret: "change-me-in-production"
    issuer: "order-service"
    audience: ""
    expiry: 3600
  allowed_services: []
{{- end }}

cache:
  driver: memory

distributed_lock:
  enabled: false
  backend: redis
  redis:
    addr: "${REDIS_ADDR:localhost:6379}"
    password: ""
    db: 0
  key_prefix: lock:

message_queue:
  enabled: false
  backend: redis
  redis:
    addr: "${REDIS_ADDR:localhost:6379}"
    password: ""
    db: 0

# 治理覆盖配置
governance:
{{- if .IsMicroserviceMode }}
  disable: []
  providers:
    tracing: otel
    selector: p2c_ewma
    serviceauth: token
    circuitbreaker: sentinel
{{- else }}
  disable: []
  providers: {}
{{- end }}

# circuit_breaker 配置
circuit_breaker:
{{- if .IsMicroserviceMode }}
  enabled: true
  backend: sentinel
  sentinel:
    strategy: error_count
    threshold: 50
    retry_timeout_ms: 5000
{{- else }}
  enabled: false
  backend: sentinel
{{- end }}

# selector 配置
selector:
{{- if .IsMicroserviceMode }}
  enabled: true
  backend: p2c_ewma
{{- else }}
  enabled: false
  backend: random
{{- end }}

services:
  user_service:
    name: "http://localhost:8081"
    timeout: 10s
    # retry: 3  # 如需 client 侧重试，再按资源调用显式开启

