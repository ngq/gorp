// Package service 服务层。
package service

import (
	"context"
	"fmt"
	"time"

	"{{.ModuleName}}/services/product/internal/biz"
	"{{.ModuleName}}/services/product/internal/data"

	"github.com/ngq/gorp/framework/contract"
	"gorm.io/gorm"
)

// Services 服务层聚合。
type Services struct {
	Product *ProductService
}

// NewServices 创建服务层。
func NewServices(db *gorm.DB, publisher contract.MessagePublisher, subscriber contract.MessageSubscriber) *Services {
	productRepo := data.NewProductRepo(db)
	productUC := biz.NewProductUseCase(productRepo)
	return &Services{
		Product: &ProductService{uc: productUC, publisher: publisher, subscriber: subscriber},
	}
}

// ProductService 商品服务。
type ProductService struct {
	uc         *biz.ProductUseCase
	publisher  contract.MessagePublisher
	subscriber contract.MessageSubscriber
}

// CreateProductRequest 创建商品请求。
type CreateProductRequest struct {
	Name        string  `json:"name" binding:"required"`
	Description string  `json:"description"`
	Price       float64 `json:"price" binding:"required"`
	Stock       int     `json:"stock"`
}

// ProductResponse 商品响应。
type ProductResponse struct {
	ID          uint    `json:"id"`
	Name        string  `json:"name"`
	Description string  `json:"description"`
	Price       float64 `json:"price"`
	Stock       int     `json:"stock"`
	CreatedAt   int64   `json:"created_at"`
	UpdatedAt   int64   `json:"updated_at"`
}

// MQConsumeResponse MQ 消费验证响应。
type MQConsumeResponse struct {
	Topic   string `json:"topic"`
	Body    string `json:"body"`
	Success bool   `json:"success"`
}

// List 获取商品列表。
func (s *ProductService) List(ctx context.Context, page, size int) ([]ProductResponse, int64, error) {
	products, total, err := s.uc.List(ctx, page, size)
	if err != nil {
		return nil, 0, err
	}

	items := make([]ProductResponse, len(products))
	for i, p := range products {
		items[i] = toProductResponse(p)
	}
	return items, total, nil
}

// GetByID 获取单个商品。
func (s *ProductService) GetByID(ctx context.Context, id uint) (*ProductResponse, error) {
	product, err := s.uc.GetByID(ctx, id)
	if err != nil {
		return nil, err
	}
	resp := toProductResponse(product)
	return &resp, nil
}

// Create 创建商品。
func (s *ProductService) Create(ctx context.Context, req CreateProductRequest) (*ProductResponse, error) {
	product, err := s.uc.Create(ctx, req.Name, req.Description, req.Price, req.Stock)
	if err != nil {
		return nil, err
	}
	resp := toProductResponse(product)
	return &resp, nil
}

// Delete 删除商品。
func (s *ProductService) Delete(ctx context.Context, id uint) error {
	return s.uc.Delete(ctx, id)
}

// PublishStockChanged 发布一个最小 MQ 样板事件。
func (s *ProductService) PublishStockChanged(ctx context.Context, id uint) (map[string]any, error) {
	body := fmt.Sprintf("product:%d stock-changed", id)
	if err := s.publisher.Publish(ctx, "product.stock.changed", []byte(body)); err != nil {
		return nil, err
	}
	return map[string]any{"topic": "product.stock.changed", "body": body, "success": true}, nil
}

// ConsumeStockChangedOnce 以单次消费方式验证 MQ 订阅能力。
func (s *ProductService) ConsumeStockChangedOnce(ctx context.Context) (*MQConsumeResponse, error) {
	ctx, cancel := context.WithTimeout(ctx, 2*time.Second)
	defer cancel()

	resultCh := make(chan *contract.Message, 1)
	errCh := make(chan error, 1)
	go func() {
		err := s.subscriber.Consume(ctx, "product.stock.changed", func(_ context.Context, message *contract.Message) error {
			resultCh <- message
			return nil
		})
		if err != nil && err != context.DeadlineExceeded && err != context.Canceled {
			errCh <- err
		}
	}()

	select {
	case msg := <-resultCh:
		return &MQConsumeResponse{Topic: msg.Topic, Body: string(msg.Body), Success: true}, nil
	case err := <-errCh:
		return nil, err
	case <-ctx.Done():
		return nil, context.DeadlineExceeded
	}
}

// toProductResponse 转换为响应格式。
func toProductResponse(p *biz.Product) ProductResponse {
	return ProductResponse{ID: p.ID, Name: p.Name, Description: p.Description, Price: p.Price, Stock: p.Stock, CreatedAt: p.CreatedAt.Unix(), UpdatedAt: p.UpdatedAt.Unix()}
}
