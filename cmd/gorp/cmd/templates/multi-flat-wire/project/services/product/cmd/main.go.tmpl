package main

import (
	"fmt"
	"os"

	productdata "{{.ModuleName}}/services/product/internal/data"
	productserver "{{.ModuleName}}/services/product/internal/server"
	frameworkbootstrap "{{.FrameworkModule}}/framework/bootstrap"
	frameworkcontainer "{{.FrameworkModule}}/framework/container"
)

// main 是 product 服务的主入口。
func main() {
	if err := frameworkbootstrap.BootHTTPService("product-service", frameworkbootstrap.HTTPServiceOptions{}, migrate, setup); err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
}

func migrate(rt *frameworkbootstrap.HTTPServiceRuntime) error {
	return frameworkbootstrap.AutoMigrateModels(rt, &productdata.ProductPO{})
}

func setup(rt *frameworkbootstrap.HTTPServiceRuntime) error {
	if rt.DB == nil {
		return fmt.Errorf("product-service requires gorm database")
	}
	publisher, err := frameworkcontainer.MakeMessagePublisher(rt.Container)
	if err != nil {
		return err
	}
	subscriber, err := frameworkcontainer.MakeMessageSubscriber(rt.Container)
	if err != nil {
		return err
	}
	services, err := wireProductServices(rt.DB, publisher, subscriber)
	if err != nil {
		return err
	}
	httpServer := productserver.NewHTTPServer(services)
	httpServer.RegisterRoutes(rt.Engine)
	return nil
}
