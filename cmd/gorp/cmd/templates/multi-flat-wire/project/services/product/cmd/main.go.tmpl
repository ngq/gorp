package main

import (
	"fmt"
	"os"

	productdata "{{.ModuleName}}/services/product/internal/data"
	producthttp "{{.ModuleName}}/services/product/internal/server/http"
	"{{.FrameworkModule}}"
{{- if .IsMicroGovernance }}
	_ "{{.ModuleName}}/shared" // 微服务治理组件统一导入
{{- end }}
{{- if .IsGinHTTPMode }}
	transportcontract "{{.FrameworkModule}}/framework/contract/transport"
{{- end }}
)

// main 是 product 服务的主入口。
func main() {
	if err := gorp.Run(
{{- if .IsMicroGovernance }}
		gorp.GRPC(),
		gorp.WithMicroGovernance(),
{{- else }}
		gorp.WithMonoGovernance(),
{{- end }}
{{- if .IsGinHTTPMode }}
		gorp.WithGinHTTPMode(),
{{- end }}
		gorp.WithMigrate(migrate),
		gorp.WithSetup(setup),
	); err != nil {
		fmt.Fprintln(os.Stderr, err)
		os.Exit(1)
	}
}

func migrate(rt *gorp.HTTPRuntime) error {
	if rt == nil || rt.DB == nil {
		return nil
	}
	return rt.DB.AutoMigrate(&productdata.ProductPO{})
}

func setup(rt *gorp.HTTPRuntime) error {
	if rt.DB == nil {
		return fmt.Errorf("product-service requires gorm database")
	}
	publisher, err := gorp.MakeMessagePublisher(rt.Container)
	if err != nil {
		return err
	}
	subscriber, err := gorp.MakeMessageSubscriber(rt.Container)
	if err != nil {
		return err
	}
	services, err := wireProductServices(rt.DB, publisher, subscriber)
	if err != nil {
		return err
	}
{{- if .IsGinHTTPMode }}

	// Gin-first 模式：传递 HTTP 服务给路由注册函数
	httpSvc, err := rt.Container.Make(transportcontract.HTTPKey)
	if err != nil {
		return err
	}
	producthttp.RegisterRoutes(httpSvc.(transportcontract.HTTP), services)
{{- else }}
	producthttp.RegisterRoutes(rt.Router, services)
{{- end }}
	return nil
}
